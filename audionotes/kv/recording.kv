# kv/recording.kv — Diseño "Sonic Clarity" (MD3 light theme)

<RecordingScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: [24, 0, 24, 32]
        spacing: 0
        canvas.before:
            Color:
                rgba: 0.973, 0.976, 0.980, 1
            Rectangle:
                pos: self.pos
                size: self.size

        # ── Barra superior ────────────────────────────
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: 64
            padding: [0, 0, 0, 0]

            Button:
                text: "Cancelar"
                size_hint_x: None
                width: 90
                font_size: 14
                background_color: 0, 0, 0, 0
                color: 0.620, 0.247, 0.306, 1
                on_press: root.cancelar()

            Widget:

        Widget:
            size_hint_y: None
            height: 20

        # ── Indicador REC ─────────────────────────────
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: 36
            spacing: 8
            padding: [0, 0]

            Label:
                text: "●"
                font_size: 20
                color: 0.620, 0.247, 0.306, 1
                size_hint_x: None
                width: 28
                halign: 'right'

            Label:
                text: "GRABANDO"
                font_size: 14
                bold: True
                color: 0.620, 0.247, 0.306, 1
                halign: 'left'
                text_size: self.width, None

        Widget:
            size_hint_y: None
            height: 16

        # ── Temporizador ──────────────────────────────
        Label:
            id: lbl_timer
            text: "00:00"
            font_size: 72
            bold: True
            color: 0.169, 0.204, 0.216, 1
            halign: 'center'
            size_hint_y: None
            height: 100

        Widget:
            size_hint_y: None
            height: 24

        # ── Waveform ──────────────────────────────────
        WaveformWidget:
            size_hint_y: None
            height: 120

        Widget:
            size_hint_y: 1

        # ── Card de info ──────────────────────────────
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: 64
            padding: [20, 14]
            spacing: 4
            canvas.before:
                Color:
                    rgba: 0.918, 0.937, 0.945, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [16]

            Label:
                text: "La grabacion se procesará automaticamente al detener"
                font_size: 13
                color: 0.345, 0.376, 0.392, 1
                halign: 'center'
                text_size: self.width, None

        Widget:
            size_hint_y: None
            height: 20

        # ── Botón detener ─────────────────────────────
        Button:
            text: "  Detener y procesar"
            size_hint: 1, None
            height: 56
            background_color: 0, 0, 0, 0
            background_normal: ''
            color: 1, 1, 1, 1
            font_size: 16
            bold: True
            on_press: root.detener_y_procesar()
            canvas.before:
                Color:
                    rgba: 0, 0.298, 0.929, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [28]
