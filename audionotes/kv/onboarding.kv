# kv/onboarding.kv — Diseño "Sonic Clarity" (MD3 light theme)

# ─────────────────────────────────────────────
# Pantalla 1: Bienvenida
# ─────────────────────────────────────────────
<OnboardingWelcomeScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: [32, 0, 32, 40]
        spacing: 0
        canvas.before:
            Color:
                rgba: 0.973, 0.976, 0.980, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Widget:
            size_hint_y: None
            height: 64

        # Ícono / hero
        Label:
            text: "mic"
            font_size: 64
            size_hint_y: None
            height: 88
            color: 0, 0.298, 0.929, 1

        Widget:
            size_hint_y: None
            height: 24

        # Etiqueta pequeña
        Label:
            text: "BIENVENIDO A"
            font_size: 12
            color: 0.345, 0.376, 0.392, 1
            halign: 'center'
            text_size: self.width, None
            size_hint_y: None
            height: 22

        # Título editorial
        Label:
            text: "Audionotes"
            font_size: 42
            bold: True
            color: 0.169, 0.204, 0.216, 1
            halign: 'center'
            text_size: self.width, None
            size_hint_y: None
            height: 56

        # Parte del título en primary
        Label:
            text: "Tu voz, perfectamente capturada."
            font_size: 16
            color: 0, 0.298, 0.929, 1
            halign: 'center'
            text_size: self.width, None
            size_hint_y: None
            height: 32

        Widget:
            size_hint_y: None
            height: 16

        # Descripción
        Label:
            text: "Graba audio. Obtén transcripción.\nTodo organizado en tu Google Drive."
            font_size: 15
            color: 0.345, 0.376, 0.392, 1
            halign: 'center'
            text_size: self.width, None
            size_hint_y: None
            height: 52

        Widget:
            size_hint_y: 1

        # Botón primario
        Button:
            text: "Comenzar"
            size_hint: 1, None
            height: 56
            background_color: 0, 0, 0, 0
            background_normal: ''
            color: 1, 1, 1, 1
            font_size: 17
            bold: True
            on_press: root.ir_a_apikey()
            canvas.before:
                Color:
                    rgba: 0, 0.298, 0.929, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [28]

# ─────────────────────────────────────────────
# Pantalla 2: API Key
# ─────────────────────────────────────────────
<OnboardingApiKeyScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: [24, 0, 24, 32]
        spacing: 0
        canvas.before:
            Color:
                rgba: 0.973, 0.976, 0.980, 1
            Rectangle:
                pos: self.pos
                size: self.size

        # AppBar minimal
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: 64
            padding: [0, 0, 0, 0]

            Button:
                text: "< Volver"
                size_hint_x: None
                width: 90
                font_size: 14
                background_color: 0, 0, 0, 0
                color: 0, 0.298, 0.929, 1
                on_press: root.ir_atras()

            Widget:

        Widget:
            size_hint_y: None
            height: 12

        Label:
            text: "Paso 1 de 4"
            font_size: 12
            color: 0.345, 0.376, 0.392, 1
            halign: 'left'
            text_size: self.width, None
            size_hint_y: None
            height: 22

        Label:
            text: "API Key de\nGoogle AI Studio"
            font_size: 28
            bold: True
            color: 0.169, 0.204, 0.216, 1
            halign: 'left'
            text_size: self.width, None
            size_hint_y: None
            height: 72

        Widget:
            size_hint_y: None
            height: 8

        Label:
            text: "1. Ve a aistudio.google.com\n2. Crea o selecciona un proyecto\n3. Genera una API key y pégala aquí"
            font_size: 14
            color: 0.345, 0.376, 0.392, 1
            halign: 'left'
            text_size: self.width, None
            size_hint_y: None
            height: 72

        Widget:
            size_hint_y: None
            height: 16

        TextInput:
            id: input_apikey
            hint_text: "Pega tu API key aquí"
            password: True
            multiline: False
            size_hint_y: None
            height: 56
            background_color: 0.918, 0.937, 0.945, 1
            foreground_color: 0.169, 0.204, 0.216, 1
            hint_text_color: 0.671, 0.702, 0.718, 1
            cursor_color: 0, 0.298, 0.929, 1
            font_size: 14
            padding: [16, 18]

        Label:
            id: lbl_error
            text: ""
            color: 0.620, 0.247, 0.306, 1
            font_size: 13
            halign: 'left'
            text_size: self.width, None
            size_hint_y: None
            height: 28

        Widget:
            size_hint_y: 1

        Button:
            text: "Verificar y continuar"
            size_hint: 1, None
            height: 56
            background_color: 0, 0, 0, 0
            background_normal: ''
            color: 1, 1, 1, 1
            font_size: 16
            bold: True
            on_press: root.verificar_y_continuar()
            canvas.before:
                Color:
                    rgba: 0, 0.298, 0.929, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [28]

# ─────────────────────────────────────────────
# Pantalla 3: OAuth Google
# ─────────────────────────────────────────────
<OnboardingOAuthScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: [24, 0, 24, 32]
        spacing: 0
        canvas.before:
            Color:
                rgba: 0.973, 0.976, 0.980, 1
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: 64

            Button:
                text: "< Volver"
                size_hint_x: None
                width: 90
                font_size: 14
                background_color: 0, 0, 0, 0
                color: 0, 0.298, 0.929, 1
                on_press: root.ir_atras()

            Widget:

        Widget:
            size_hint_y: None
            height: 12

        Label:
            text: "Paso 2 de 4"
            font_size: 12
            color: 0.345, 0.376, 0.392, 1
            halign: 'left'
            text_size: self.width, None
            size_hint_y: None
            height: 22

        Label:
            text: "Conectar con\nGoogle Drive"
            font_size: 28
            bold: True
            color: 0.169, 0.204, 0.216, 1
            halign: 'left'
            text_size: self.width, None
            size_hint_y: None
            height: 72

        Widget:
            size_hint_y: None
            height: 8

        Label:
            text: "Audionotes guardará tus grabaciones en una carpeta de tu Google Drive. Presiona el botón para autorizar el acceso."
            font_size: 14
            color: 0.345, 0.376, 0.392, 1
            halign: 'left'
            text_size: self.width, None
            size_hint_y: None
            height: 64

        Widget:
            size_hint_y: None
            height: 16

        # Botón OAuth (verde Google-ish)
        Button:
            text: "Abrir Google para autorizar"
            size_hint: 1, None
            height: 52
            background_color: 0, 0, 0, 0
            background_normal: ''
            color: 1, 1, 1, 1
            font_size: 15
            on_press: root.simular_abrir_navegador()
            canvas.before:
                Color:
                    rgba: 0.114, 0.533, 0.349, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [26]

        Label:
            id: lbl_oauth_status
            text: ""
            color: 0.114, 0.533, 0.349, 1
            font_size: 13
            halign: 'left'
            text_size: self.width, None
            size_hint_y: None
            height: 28

        Widget:
            size_hint_y: None
            height: 8

        Label:
            text: "Código de autorización de Google:"
            font_size: 14
            color: 0.345, 0.376, 0.392, 1
            halign: 'left'
            text_size: self.width, None
            size_hint_y: None
            height: 32

        TextInput:
            id: input_codigo_oauth
            hint_text: "Pega el código aquí"
            multiline: False
            size_hint_y: None
            height: 56
            background_color: 0.918, 0.937, 0.945, 1
            foreground_color: 0.169, 0.204, 0.216, 1
            hint_text_color: 0.671, 0.702, 0.718, 1
            cursor_color: 0, 0.298, 0.929, 1
            font_size: 14
            padding: [16, 18]

        Label:
            id: lbl_error_oauth
            text: ""
            color: 0.620, 0.247, 0.306, 1
            font_size: 13
            halign: 'left'
            text_size: self.width, None
            size_hint_y: None
            height: 28

        Widget:
            size_hint_y: 1

        Button:
            text: "Confirmar"
            size_hint: 1, None
            height: 56
            background_color: 0, 0, 0, 0
            background_normal: ''
            color: 1, 1, 1, 1
            font_size: 16
            bold: True
            on_press: root.confirmar_codigo()
            canvas.before:
                Color:
                    rgba: 0, 0.298, 0.929, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [28]

# ─────────────────────────────────────────────
# Pantalla 4: ID de carpeta Drive
# ─────────────────────────────────────────────
<OnboardingDriveScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: [24, 0, 24, 32]
        spacing: 0
        canvas.before:
            Color:
                rgba: 0.973, 0.976, 0.980, 1
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: 64

            Button:
                text: "< Volver"
                size_hint_x: None
                width: 90
                font_size: 14
                background_color: 0, 0, 0, 0
                color: 0, 0.298, 0.929, 1
                on_press: root.ir_atras()

            Widget:

        Widget:
            size_hint_y: None
            height: 12

        Label:
            text: "Paso 3 de 4"
            font_size: 12
            color: 0.345, 0.376, 0.392, 1
            halign: 'left'
            text_size: self.width, None
            size_hint_y: None
            height: 22

        Label:
            text: "Carpeta de\nGoogle Drive"
            font_size: 28
            bold: True
            color: 0.169, 0.204, 0.216, 1
            halign: 'left'
            text_size: self.width, None
            size_hint_y: None
            height: 72

        Widget:
            size_hint_y: None
            height: 8

        Label:
            text: "Abre Google Drive, navega a tu carpeta de grabaciones y copia el ID que aparece al final de la URL:"
            font_size: 14
            color: 0.345, 0.376, 0.392, 1
            halign: 'left'
            text_size: self.width, None
            size_hint_y: None
            height: 64

        # URL de ejemplo
        BoxLayout:
            size_hint_y: None
            height: 44
            padding: [14, 10]
            canvas.before:
                Color:
                    rgba: 0.867, 0.882, 1, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [10]

            Label:
                text: "drive.google.com/drive/folders/[ID]"
                font_size: 12
                color: 0, 0.259, 0.820, 1
                halign: 'left'
                text_size: self.width, None

        Widget:
            size_hint_y: None
            height: 16

        TextInput:
            id: input_folder_id
            hint_text: "ID de carpeta de Drive"
            multiline: False
            size_hint_y: None
            height: 56
            background_color: 0.918, 0.937, 0.945, 1
            foreground_color: 0.169, 0.204, 0.216, 1
            hint_text_color: 0.671, 0.702, 0.718, 1
            cursor_color: 0, 0.298, 0.929, 1
            font_size: 14
            padding: [16, 18]

        Label:
            id: lbl_error_drive
            text: ""
            color: 0.620, 0.247, 0.306, 1
            font_size: 13
            halign: 'left'
            text_size: self.width, None
            size_hint_y: None
            height: 28

        Widget:
            size_hint_y: 1

        Button:
            text: "Verificar y continuar"
            size_hint: 1, None
            height: 56
            background_color: 0, 0, 0, 0
            background_normal: ''
            color: 1, 1, 1, 1
            font_size: 16
            bold: True
            on_press: root.verificar_y_continuar()
            canvas.before:
                Color:
                    rgba: 0, 0.298, 0.929, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [28]

# ─────────────────────────────────────────────
# Pantalla 5: Permisos del dispositivo
# ─────────────────────────────────────────────
<OnboardingPermissionsScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: [24, 0, 24, 32]
        spacing: 0
        canvas.before:
            Color:
                rgba: 0.973, 0.976, 0.980, 1
            Rectangle:
                pos: self.pos
                size: self.size

        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: 64

            Button:
                text: "< Volver"
                size_hint_x: None
                width: 90
                font_size: 14
                background_color: 0, 0, 0, 0
                color: 0, 0.298, 0.929, 1
                on_press: root.ir_atras()

            Widget:

        Widget:
            size_hint_y: None
            height: 12

        Label:
            text: "Paso 4 de 4"
            font_size: 12
            color: 0.345, 0.376, 0.392, 1
            halign: 'left'
            text_size: self.width, None
            size_hint_y: None
            height: 22

        Label:
            text: "Permisos del\ndispositivo"
            font_size: 28
            bold: True
            color: 0.169, 0.204, 0.216, 1
            halign: 'left'
            text_size: self.width, None
            size_hint_y: None
            height: 72

        Widget:
            size_hint_y: None
            height: 16

        # Card de permisos
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: 120
            padding: [20, 16]
            spacing: 10
            canvas.before:
                Color:
                    rgba: 1, 1, 1, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [16]

            Label:
                text: "Microfono — para grabar audio"
                font_size: 14
                color: 0.169, 0.204, 0.216, 1
                halign: 'left'
                text_size: self.width, None

            Label:
                text: "Almacenamiento — guardar temporalmente"
                font_size: 14
                color: 0.169, 0.204, 0.216, 1
                halign: 'left'
                text_size: self.width, None

            Label:
                text: "Internet — enviar a Gemini y Drive"
                font_size: 14
                color: 0.169, 0.204, 0.216, 1
                halign: 'left'
                text_size: self.width, None

        Widget:
            size_hint_y: None
            height: 16

        Button:
            id: btn_permisos
            text: "Conceder permisos"
            size_hint: 1, None
            height: 52
            background_color: 0, 0, 0, 0
            background_normal: ''
            color: 0, 0.259, 0.820, 1
            font_size: 15
            on_press: root.solicitar_permisos()
            canvas.before:
                Color:
                    rgba: 0.867, 0.882, 1, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [26]

        Label:
            id: lbl_permisos_status
            text: ""
            color: 0.114, 0.533, 0.349, 1
            font_size: 13
            halign: 'left'
            text_size: self.width, None
            size_hint_y: None
            height: 28

        Widget:
            size_hint_y: 1

        Button:
            text: "Continuar"
            size_hint: 1, None
            height: 56
            background_color: 0, 0, 0, 0
            background_normal: ''
            color: 1, 1, 1, 1
            font_size: 16
            bold: True
            on_press: root.continuar()
            canvas.before:
                Color:
                    rgba: 0, 0.298, 0.929, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [28]

# ─────────────────────────────────────────────
# Pantalla 6: Onboarding completado
# ─────────────────────────────────────────────
<OnboardingDoneScreen>:
    BoxLayout:
        orientation: 'vertical'
        padding: [32, 0, 32, 48]
        spacing: 0
        canvas.before:
            Color:
                rgba: 0.973, 0.976, 0.980, 1
            Rectangle:
                pos: self.pos
                size: self.size

        Widget:
            size_hint_y: 0.18

        # Check grande
        Label:
            text: "OK"
            font_size: 56
            bold: True
            size_hint_y: None
            height: 88
            color: 0.114, 0.533, 0.349, 1

        Widget:
            size_hint_y: None
            height: 24

        Label:
            text: "Todo listo."
            font_size: 32
            bold: True
            color: 0.169, 0.204, 0.216, 1
            halign: 'center'
            text_size: self.width, None
            size_hint_y: None
            height: 48

        Label:
            text: "Ya puedes grabar tu primera nota."
            font_size: 16
            color: 0.345, 0.376, 0.392, 1
            halign: 'center'
            text_size: self.width, None
            size_hint_y: None
            height: 32

        Widget:
            size_hint_y: 1

        Button:
            text: "Ir a Audionotes"
            size_hint: 1, None
            height: 56
            background_color: 0, 0, 0, 0
            background_normal: ''
            color: 1, 1, 1, 1
            font_size: 17
            bold: True
            on_press: root.ir_a_la_app()
            canvas.before:
                Color:
                    rgba: 0, 0.298, 0.929, 1
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [28]
