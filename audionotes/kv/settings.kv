# kv/settings.kv — Diseño "Sonic Clarity" (MD3 light theme)

<SettingsScreen>:
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: 0.973, 0.976, 0.980, 1
            Rectangle:
                pos: self.pos
                size: self.size

        # ── TopAppBar ─────────────────────────────────
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: None
            height: 64
            padding: [8, 0, 20, 0]
            canvas.before:
                Color:
                    rgba: 0.945, 0.957, 0.965, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            Button:
                text: "< Volver"
                size_hint_x: None
                width: 90
                font_size: 14
                background_color: 0, 0, 0, 0
                color: 0, 0.298, 0.929, 1
                on_press: root.volver()

            Label:
                text: "Ajustes"
                font_size: 20
                bold: True
                color: 0.169, 0.204, 0.216, 1
                halign: 'left'
                text_size: self.width, None

        # ── Contenido scrollable ──────────────────────
        ScrollView:
            BoxLayout:
                orientation: 'vertical'
                padding: [24, 20, 24, 32]
                spacing: 0
                size_hint_y: None
                height: self.minimum_height

                # ── Sección: Configuración de IA ─────────
                Label:
                    text: "CONFIGURACION"
                    font_size: 11
                    color: 0.345, 0.376, 0.392, 1
                    halign: 'left'
                    text_size: self.width, None
                    size_hint_y: None
                    height: 28

                # Card de configuracion
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: 200
                    padding: [16, 16]
                    spacing: 8
                    canvas.before:
                        Color:
                            rgba: 1, 1, 1, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [16]

                    Label:
                        text: "API Key de Google AI Studio"
                        font_size: 13
                        color: 0.345, 0.376, 0.392, 1
                        halign: 'left'
                        text_size: self.width, None
                        size_hint_y: None
                        height: 24

                    TextInput:
                        id: input_apikey
                        hint_text: "Tu API key"
                        password: True
                        multiline: False
                        size_hint_y: None
                        height: 52
                        background_color: 0.918, 0.937, 0.945, 1
                        foreground_color: 0.169, 0.204, 0.216, 1
                        hint_text_color: 0.671, 0.702, 0.718, 1
                        cursor_color: 0, 0.298, 0.929, 1
                        font_size: 14
                        padding: [14, 16]

                    Label:
                        text: "ID de carpeta de Google Drive"
                        font_size: 13
                        color: 0.345, 0.376, 0.392, 1
                        halign: 'left'
                        text_size: self.width, None
                        size_hint_y: None
                        height: 24

                    TextInput:
                        id: input_folder_id
                        hint_text: "ID de la carpeta en Drive"
                        multiline: False
                        size_hint_y: None
                        height: 52
                        background_color: 0.918, 0.937, 0.945, 1
                        foreground_color: 0.169, 0.204, 0.216, 1
                        hint_text_color: 0.671, 0.702, 0.718, 1
                        cursor_color: 0, 0.298, 0.929, 1
                        font_size: 14
                        padding: [14, 16]

                # Mensaje de estado
                Label:
                    id: lbl_mensaje
                    text: ""
                    color: 0.114, 0.533, 0.349, 1
                    font_size: 13
                    halign: 'left'
                    text_size: self.width, None
                    size_hint_y: None
                    height: 28

                Widget:
                    size_hint_y: None
                    height: 8

                Button:
                    text: "Guardar cambios"
                    size_hint: 1, None
                    height: 52
                    background_color: 0, 0, 0, 0
                    background_normal: ''
                    color: 1, 1, 1, 1
                    font_size: 15
                    bold: True
                    on_press: root.guardar_cambios()
                    canvas.before:
                        Color:
                            rgba: 0, 0.298, 0.929, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [26]

                Widget:
                    size_hint_y: None
                    height: 28

                # ── Sección: Cuenta ──────────────────────
                Label:
                    text: "CUENTA DE GOOGLE"
                    font_size: 11
                    color: 0.345, 0.376, 0.392, 1
                    halign: 'left'
                    text_size: self.width, None
                    size_hint_y: None
                    height: 28

                Button:
                    text: "Desconectar cuenta de Google"
                    size_hint: 1, None
                    height: 48
                    background_color: 0, 0, 0, 0
                    background_normal: ''
                    color: 0.620, 0.247, 0.306, 1
                    font_size: 14
                    on_press: root.desconectar_google()
                    canvas.before:
                        Color:
                            rgba: 1, 0.910, 0.918, 1
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [24]

                Widget:
                    size_hint_y: None
                    height: 32

                # ── Sección: Información ─────────────────
                Label:
                    text: "ACERCA DE"
                    font_size: 11
                    color: 0.345, 0.376, 0.392, 1
                    halign: 'left'
                    text_size: self.width, None
                    size_hint_y: None
                    height: 28

                Label:
                    id: lbl_version
                    text: ""
                    font_size: 13
                    color: 0.451, 0.486, 0.498, 1
                    halign: 'left'
                    text_size: self.width, None
                    size_hint_y: None
                    height: 24

                Label:
                    text: "github.com/juankeyboard/audionotes"
                    font_size: 13
                    color: 0, 0.298, 0.929, 1
                    halign: 'left'
                    text_size: self.width, None
                    size_hint_y: None
                    height: 24
